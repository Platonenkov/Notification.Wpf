<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:constants="clr-namespace:Notification.Wpf.Constants"
    xmlns:controls="clr-namespace:Notification.Wpf.Controls"
    xmlns:converters="clr-namespace:Notification.Wpf.Converters"
    xmlns:fa5="http://schemas.fontawesome.com/icons/"
    xmlns:p="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
    xmlns:system="clr-namespace:System;assembly=mscorlib"
    xmlns:wpf="clr-namespace:Notification.Wpf">

    <SolidColorBrush
        x:Key="BorderBrush"
        p:Freeze="True"
        Color="#EEE" />
    <SolidColorBrush
        x:Key="TransparentBrush"
        p:Freeze="True"
        Color="Transparent" />
    <SolidColorBrush
        x:Key="WhiteBrush"
        p:Freeze="True"
        Color="White" />
    <SolidColorBrush
        x:Key="WhiteSmokeBrush"
        p:Freeze="True"
        Color="WhiteSmoke" />
    <SolidColorBrush
        x:Key="BlackBrush"
        p:Freeze="True"
        Color="Black" />
    <SolidColorBrush
        x:Key="GrayBrush"
        p:Freeze="True"
        Color="Gray" />
    <SolidColorBrush
        x:Key="LightGrayBrush"
        p:Freeze="True"
        Color="LightGray" />
    <SolidColorBrush
        x:Key="DarkGrayBrush"
        p:Freeze="True"
        Color="DarkGray" />
    <SolidColorBrush
        x:Key="DarkRedBrush"
        p:Freeze="True"
        Color="DarkRed" />
    <SolidColorBrush
        x:Key="RedBrush"
        p:Freeze="True"
        Color="Red" />
    <SolidColorBrush
        x:Key="DarkOrangeBrush"
        p:Freeze="True"
        Color="DarkOrange" />
    <SolidColorBrush
        x:Key="OrangeRedBrush"
        p:Freeze="True"
        Color="OrangeRed" />
    <SolidColorBrush
        x:Key="OrangeBrush"
        p:Freeze="True"
        Color="Orange" />
    <SolidColorBrush
        x:Key="YellowBrush"
        p:Freeze="True"
        Color="Yellow" />
    <SolidColorBrush
        x:Key="LightYellowBrush"
        p:Freeze="True"
        Color="LightYellow" />
    <SolidColorBrush
        x:Key="GreenBrush"
        p:Freeze="True"
        Color="Green" />
    <SolidColorBrush
        x:Key="LimeGreenBrush"
        p:Freeze="True"
        Color="LimeGreen" />
    <SolidColorBrush
        x:Key="BlueBrush"
        p:Freeze="True"
        Color="Blue" />
    <SolidColorBrush
        x:Key="LimeBrush"
        p:Freeze="True"
        Color="Lime" />
    <SolidColorBrush
        x:Key="DarkBlueBrush"
        p:Freeze="True"
        Color="DarkBlue" />
    <DropShadowEffect x:Key="Shadow" p:Freeze="True" />
    <ScaleTransform x:Key="Scale1.1" p:Freeze="True" ScaleX="1.1" ScaleY="1.1" />
    <ScaleTransform x:Key="Scale0.9" p:Freeze="True" ScaleX="0.9" ScaleY="0.9" />

    <Color
        x:Key="WhiteColor"
        A="255"
        B="255"
        G="255"
        R="255" />
    <Color
        x:Key="BlackColor"
        A="255"
        B="0"
        G="0"
        R="0" />

    <fa5:ImageAwesome
        x:Key="LinkIcon"
        Height="20"
        x:Shared="False"
        Foreground="{StaticResource WhiteBrush}"
        Icon="Solid_Link"
        Rotation="135" />
    <fa5:ImageAwesome
        x:Key="MinimizeIcon"
        Height="20"
        x:Shared="False"
        Foreground="{StaticResource WhiteBrush}"
        Icon="Regular_WindowMinimize" />
    <fa5:ImageAwesome
        x:Key="MaximizeIcon"
        Height="20"
        x:Shared="False"
        Foreground="{StaticResource WhiteBrush}"
        Icon="Regular_WindowMaximize" />
    <fa5:ImageAwesome
        x:Key="SettingIcon"
        Height="20"
        x:Shared="False"
        Foreground="{StaticResource WhiteBrush}"
        Icon="Solid_Cog" />
    <fa5:ImageAwesome
        x:Key="LoadIcon"
        Height="20"
        x:Shared="False"
        Foreground="{StaticResource WhiteBrush}"
        Icon="Solid_Spinner"
        Spin="True"
        SpinDuration="1" />
    <fa5:ImageAwesome
        x:Key="ErrorIcon"
        Height="20"
        x:Shared="False"
        Foreground="{StaticResource WhiteBrush}"
        Icon="Solid_Bug" />
    <fa5:ImageAwesome
        x:Key="CloseIcon"
        Height="12"
        x:Shared="False"
        Foreground="{StaticResource WhiteBrush}"
        Icon="Regular_WindowClose" />
    <fa5:ImageAwesome
        x:Key="AttachIcon"
        Height="25"
        x:Shared="False"
        Foreground="{StaticResource WhiteBrush}"
        Icon="Solid_Paperclip">
        <fa5:ImageAwesome.Triggers>
            <EventTrigger RoutedEvent="fa5:ImageAwesome.Loaded">
                <EventTrigger.Actions>
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimationUsingKeyFrames
                                AutoReverse="True"
                                RepeatBehavior="10x"
                                Storyboard.TargetProperty="(fa5:ImageAwesome.Foreground).(SolidColorBrush.Color)">
                                <LinearColorKeyFrame KeyTime="0:0:0" Value="{StaticResource WhiteColor}" />
                                <LinearColorKeyFrame KeyTime="0:0:1" Value="{StaticResource BlackColor}" />
                            </ColorAnimationUsingKeyFrames>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger.Actions>
            </EventTrigger>
        </fa5:ImageAwesome.Triggers>
    </fa5:ImageAwesome>

